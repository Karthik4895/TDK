# Copy this file to .env and fill in your values
ANTHROPIC_API_KEY=sk-ant-...

# App settings
APP_ENV=development        # development | production
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR

# Pipeline tuning
MAX_ITERATIONS=3           # Max refinement loops (1–5)
SCORE_THRESHOLD=8          # Minimum score to stop refining (0–10)

# Claude model (haiku = fastest/cheapest, sonnet = smarter)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Database
DB_PATH=tdk.db             # SQLite file path (relative to project root)
